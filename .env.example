# ---- Full stack (recommended) ----
# Point at the Lotus API running locally (CSIT321_Project repo).
VITE_API_BASE_URL=http://localhost:8000
VITE_USE_MOCK_API=false

# ---- Supabase (shared team project) ----
# Get the anon/public key from a teammate or the team password manager.
# Never commit .env — only this .env.example is tracked.
VITE_SUPABASE_URL=https://poizespthezmvrfhcyps.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- Mock-only mode (frontend only, no backend) ----
# Uncomment these instead if you only want UI mocks:
# VITE_API_BASE_URL=
# VITE_USE_MOCK_API=true

# ---- Vercel deploy hints (NOT used locally) ----
# These same VITE_* keys must also be set in the Vercel dashboard for BOTH the
# Production and Preview environments (Project → Settings → Environment Variables).
# See DEPLOY.md for the full env checklist and CORS update steps.
#
#   Vercel Production env:
#     VITE_API_BASE_URL      = https://vivacious-wisdom-production.up.railway.app
#     VITE_USE_MOCK_API      = false
#     VITE_SUPABASE_URL      = https://poizespthezmvrfhcyps.supabase.co
#     VITE_SUPABASE_ANON_KEY = (anon key — safe for browser, NOT service_role)
#
#   Production URL: https://lotusapp.org (Vercel also serves identical-front.vercel.app)
#
#   Vercel Preview env (same values; same Supabase project unless we add a staging project later).
