# ---- Full stack (recommended) ----
# Point at the Lotus API running locally (CSIT321_Project repo).
VITE_API_BASE_URL=http://localhost:8000
VITE_USE_MOCK_API=false

# ---- Supabase (shared team project) ----
# Get the anon/public key from a teammate or the team password manager.
# Never commit .env — only this .env.example is tracked.
VITE_SUPABASE_URL=https://poizespthezmvrfhcyps.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- Mock-only mode (frontend only, no backend) ----
# Uncomment these instead if you only want UI mocks:
# VITE_API_BASE_URL=
# VITE_USE_MOCK_API=true
